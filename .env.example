# copy to .env and fill in your own values
# either provide a pre-existing token or use the OAuth flow below
STRAVA_ACCESS_TOKEN=
STRAVA_REFRESH_TOKEN=
STRAVA_EXPIRES_AT=

# OAuth client credentials (register an app at https://www.strava.com/settings/api)
CLIENT_ID=
CLIENT_SECRET=
# optional, defaults to http://localhost:3000/callback
#REDIRECT_URI=

# PORT=3000